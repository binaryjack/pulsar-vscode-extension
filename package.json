{
  "name": "synetics-vscode",
  "displayName": "Synetics Language Support",
  "description": "Syntax highlighting and IntelliSense for Synetics (.syn) files",
  "version": "0.3.0",
  "publisher": "binaryjack",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "syn",
    "synetics",
    "reactive",
    "jsx",
    "typescript",
    "component",
    "signal"
  ],
  "activationEvents": [
    "onLanguage:syn"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "syn",
        "aliases": [
          "Synetics",
          "syn"
        ],
        "extensions": [
          ".syn"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/psr-icon-light.svg",
          "dark": "./icons/psr-icon-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "syn",
        "scopeName": "source.syn",
        "path": "./syntaxes/syn.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "syn",
        "path": "./snippets/syn.json"
      }
    ],
    "iconThemes": [
      {
        "id": "syn-icons",
        "label": "SYN File Icons",
        "path": "./fileicons/syn-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@types/vscode": "^1.108.1",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/binaryjack/synetics-vscode-extension"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
