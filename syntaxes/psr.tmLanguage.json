{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PSR",
  "scopeName": "source.psr",
  "patterns": [
    { "include": "#comments" },
    { "include": "#component-declaration" },
    { "include": "#signal-declaration" },
    { "include": "#jsx" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.psr",
          "match": "//.*$"
        },
        {
          "name": "comment.block.psr",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "component-declaration": {
      "patterns": [
        {
          "name": "meta.component.psr",
          "match": "\\b(component)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.component.psr" },
            "2": { "name": "entity.name.function.component.psr" }
          }
        }
      ]
    },
    "signal-declaration": {
      "patterns": [
        {
          "name": "meta.signal.psr",
          "match": "\\b(signal|createSignal|createEffect|createMemo)\\b",
          "captures": {
            "1": { "name": "support.function.signal.psr" }
          }
        }
      ]
    },
    "jsx": {
      "patterns": [{ "include": "#jsx-level-1" }]
    },
    "jsx-level-1": {
      "patterns": [
        {
          "name": "meta.tag.jsx.level-1",
          "begin": "(<)([a-zA-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx.level-1" },
            "2": { "name": "entity.name.tag.jsx.level-1" }
          },
          "end": "(/>)|(</)([a-zA-Z][a-zA-Z0-9]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx.level-1" },
            "2": { "name": "punctuation.definition.tag.begin.jsx.level-1" },
            "3": { "name": "entity.name.tag.jsx.level-1" },
            "4": { "name": "punctuation.definition.tag.end.jsx.level-1" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-1" }]
        }
      ]
    },
    "jsx-level-2": {
      "patterns": [
        {
          "name": "meta.tag.jsx.level-2",
          "begin": "(<)([a-zA-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx.level-2" },
            "2": { "name": "entity.name.tag.jsx.level-2" }
          },
          "end": "(/>)|(</)([a-zA-Z][a-zA-Z0-9]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx.level-2" },
            "2": { "name": "punctuation.definition.tag.begin.jsx.level-2" },
            "3": { "name": "entity.name.tag.jsx.level-2" },
            "4": { "name": "punctuation.definition.tag.end.jsx.level-2" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-2" }]
        }
      ]
    },
    "jsx-level-3": {
      "patterns": [
        {
          "name": "meta.tag.jsx.level-3",
          "begin": "(<)([a-zA-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx.level-3" },
            "2": { "name": "entity.name.tag.jsx.level-3" }
          },
          "end": "(/>)|(</)([a-zA-Z][a-zA-Z0-9]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx.level-3" },
            "2": { "name": "punctuation.definition.tag.begin.jsx.level-3" },
            "3": { "name": "entity.name.tag.jsx.level-3" },
            "4": { "name": "punctuation.definition.tag.end.jsx.level-3" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-3" }]
        }
      ]
    },
    "jsx-level-4": {
      "patterns": [
        {
          "name": "meta.tag.jsx.level-4",
          "begin": "(<)([a-zA-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx.level-4" },
            "2": { "name": "entity.name.tag.jsx.level-4" }
          },
          "end": "(/>)|(</)([a-zA-Z][a-zA-Z0-9]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx.level-4" },
            "2": { "name": "punctuation.definition.tag.begin.jsx.level-4" },
            "3": { "name": "entity.name.tag.jsx.level-4" },
            "4": { "name": "punctuation.definition.tag.end.jsx.level-4" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-4" }]
        }
      ]
    },
    "jsx-level-5": {
      "patterns": [
        {
          "name": "meta.tag.jsx.level-5",
          "begin": "(<)([a-zA-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx.level-5" },
            "2": { "name": "entity.name.tag.jsx.level-5" }
          },
          "end": "(/>)|(</)([a-zA-Z][a-zA-Z0-9]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx.level-5" },
            "2": { "name": "punctuation.definition.tag.begin.jsx.level-5" },
            "3": { "name": "entity.name.tag.jsx.level-5" },
            "4": { "name": "punctuation.definition.tag.end.jsx.level-5" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children" }]
        }
      ]
    },
    "jsx-attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.jsx",
          "match": "\\b[a-zA-Z][a-zA-Z0-9-]*\\b(?==)"
        },
        {
          "name": "string.quoted.double.jsx",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.jsx",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.jsx",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.jsx",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "meta.embedded.expression.jsx",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "$self" }]
        }
      ]
    },
    "jsx-children": {
      "patterns": [
        {
          "name": "meta.jsx.text.jsx",
          "match": "[^<>{}&]+",
          "comment": "Plain text content between JSX tags"
        },
        {
          "name": "meta.embedded.expression.jsx",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "$self" }]
        },
        { "include": "#jsx-level-1" }
      ]
    },
    "jsx-children-level-1": {
      "patterns": [
        {
          "name": "meta.jsx.text.jsx",
          "match": "[^<>{}&]+",
          "comment": "Plain text content between JSX tags"
        },
        {
          "name": "meta.embedded.expression.jsx",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "$self" }]
        },
        { "include": "#jsx-level-2" }
      ]
    },
    "jsx-children-level-2": {
      "patterns": [
        {
          "name": "meta.jsx.text.jsx",
          "match": "[^<>{}&]+",
          "comment": "Plain text content between JSX tags"
        },
        {
          "name": "meta.embedded.expression.jsx",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "$self" }]
        },
        { "include": "#jsx-level-3" }
      ]
    },
    "jsx-children-level-3": {
      "patterns": [
        {
          "name": "meta.jsx.text.jsx",
          "match": "[^<>{}&]+",
          "comment": "Plain text content between JSX tags"
        },
        {
          "name": "meta.embedded.expression.jsx",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "$self" }]
        },
        { "include": "#jsx-level-4" }
      ]
    },
    "jsx-children-level-4": {
      "patterns": [
        {
          "name": "meta.jsx.text.jsx",
          "match": "[^<>{}&]+",
          "comment": "Plain text content between JSX tags"
        },
        {
          "name": "meta.embedded.expression.jsx",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "$self" }]
        },
        { "include": "#jsx-level-5" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.psr",
          "match": "\\b(if|else|switch|case|default|for|while|do|break|continue|return|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.other.psr",
          "match": "\\b(const|let|var|function|async|await|import|export|from|as|default|class|interface|type|enum|namespace)\\b"
        },
        {
          "name": "storage.modifier.psr",
          "match": "\\b(public|private|protected|readonly|static)\\b"
        },
        {
          "name": "constant.language.psr",
          "match": "\\b(true|false|null|undefined|NaN|Infinity)\\b"
        },
        {
          "name": "variable.language.psr",
          "match": "\\b(this|super)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.psr",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.psr",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.psr",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.psr",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.psr",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.template.expression.psr",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.psr",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.psr",
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.psr" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.psr",
          "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.psr",
          "match": "(\\+\\+|\\-\\-|\\+|\\-|\\*|\\/|%|===|!==|==|!=|<=|>=|<|>|&&|\\|\\||!|\\?|:|=|\\+=|\\-=|\\*=|\\/=|%=|=>)"
        }
      ]
    }
  }
}
