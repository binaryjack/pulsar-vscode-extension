{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PSR",
  "scopeName": "source.psr",
  "patterns": [
    { "include": "#comments" },
    { "include": "#component-declaration" },
    { "include": "#signal-declaration" },
    { "include": "#jsx-fragment" },
    { "include": "#jsx" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.psr",
          "match": "//.*$"
        },
        {
          "name": "comment.block.psr",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "component-declaration": {
      "patterns": [
        {
          "name": "meta.component.psr",
          "match": "\\b(component)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.component.psr" },
            "2": { "name": "entity.name.function.component.psr" }
          }
        }
      ]
    },
    "signal-declaration": {
      "patterns": [
        {
          "name": "meta.signal.psr",
          "match": "\\b(signal|createSignal|createEffect|createMemo)\\b",
          "captures": {
            "1": { "name": "support.function.signal.psr" }
          }
        }
      ]
    },
    "jsx-fragment": {
      "patterns": [
        {
          "name": "meta.tag.fragment.jsx",
          "begin": "(<>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.fragment.begin.jsx" }
          },
          "end": "(</?>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.fragment.end.jsx" }
          },
          "patterns": [
            { "include": "#jsx-fragment" },
            { "include": "#jsx-level-1" }
          ]
        }
      ]
    },
    "jsx": {
      "patterns": [
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-1" }
      ]
    },
    "jsx-level-1": {
      "patterns": [
        {
          "name": "meta.tag.component.jsx.level-1",
          "begin": "(<)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "support.class.component.jsx" }
          },
          "end": "(/>)|(<\\/)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "support.class.component.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-1" }]
        },
        {
          "name": "meta.tag.html.jsx.level-1",
          "begin": "(<)([a-z][a-zA-Z0-9-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" }
          },
          "end": "(/>)|(<\\/)([a-z][a-zA-Z0-9-]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "entity.name.tag.html.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-1" }]
        }
      ]
    },
    "jsx-level-2": {
      "patterns": [
        {
          "name": "meta.tag.component.jsx.level-2",
          "begin": "(<)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "support.class.component.jsx" }
          },
          "end": "(/>)|(<\\/)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "support.class.component.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-2" }]
        },
        {
          "name": "meta.tag.html.jsx.level-2",
          "begin": "(<)([a-z][a-zA-Z0-9-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" }
          },
          "end": "(/>)|(<\\/)([a-z][a-zA-Z0-9-]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "entity.name.tag.html.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-2" }]
        }
      ]
    },
    "jsx-level-3": {
      "patterns": [
        {
          "name": "meta.tag.component.jsx.level-3",
          "begin": "(<)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "support.class.component.jsx" }
          },
          "end": "(/>)|(<\\/)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "support.class.component.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-3" }]
        },
        {
          "name": "meta.tag.html.jsx.level-3",
          "begin": "(<)([a-z][a-zA-Z0-9-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" }
          },
          "end": "(/>)|(<\\/)([a-z][a-zA-Z0-9-]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "entity.name.tag.html.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-3" }]
        }
      ]
    },
    "jsx-level-4": {
      "patterns": [
        {
          "name": "meta.tag.component.jsx.level-4",
          "begin": "(<)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "support.class.component.jsx" }
          },
          "end": "(/>)|(<\\/)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "support.class.component.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-4" }]
        },
        {
          "name": "meta.tag.html.jsx.level-4",
          "begin": "(<)([a-z][a-zA-Z0-9-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" }
          },
          "end": "(/>)|(<\\/)([a-z][a-zA-Z0-9-]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "entity.name.tag.html.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-4" }]
        }
      ]
    },
    "jsx-level-5": {
      "patterns": [
        {
          "name": "meta.tag.component.jsx.level-5",
          "begin": "(<)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "support.class.component.jsx" }
          },
          "end": "(/>)|(<\\/)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "support.class.component.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-5" }]
        },
        {
          "name": "meta.tag.html.jsx.level-5",
          "begin": "(<)([a-z][a-zA-Z0-9-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" }
          },
          "end": "(/>)|(<\\/)([a-z][a-zA-Z0-9-]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "entity.name.tag.html.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-5" }]
        }
      ]
    },
    "jsx-level-6": {
      "patterns": [
        {
          "name": "meta.tag.component.jsx.level-6",
          "begin": "(<)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "support.class.component.jsx" }
          },
          "end": "(/>)|(<\\/)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "support.class.component.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-6" }]
        },
        {
          "name": "meta.tag.html.jsx.level-6",
          "begin": "(<)([a-z][a-zA-Z0-9-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" }
          },
          "end": "(/>)|(<\\/)([a-z][a-zA-Z0-9-]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "entity.name.tag.html.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-6" }]
        }
      ]
    },
    "jsx-level-7": {
      "patterns": [
        {
          "name": "meta.tag.component.jsx.level-7",
          "begin": "(<)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "support.class.component.jsx" }
          },
          "end": "(/>)|(<\\/)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "support.class.component.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-7" }]
        },
        {
          "name": "meta.tag.html.jsx.level-7",
          "begin": "(<)([a-z][a-zA-Z0-9-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" }
          },
          "end": "(/>)|(<\\/)([a-z][a-zA-Z0-9-]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "entity.name.tag.html.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children-level-7" }]
        }
      ]
    },
    "jsx-level-8": {
      "patterns": [
        {
          "name": "meta.tag.component.jsx.level-8",
          "begin": "(<)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "support.class.component.jsx" }
          },
          "end": "(/>)|(<\\/)((?:[A-Z][a-zA-Z0-9]*(?:\\.[A-Za-z][a-zA-Z0-9]*)*))(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "support.class.component.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children" }]
        },
        {
          "name": "meta.tag.html.jsx.level-8",
          "begin": "(<)([a-z][a-zA-Z0-9-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" }
          },
          "end": "(/>)|(<\\/)([a-z][a-zA-Z0-9-]*)(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx" },
            "2": { "name": "punctuation.definition.tag.begin.jsx" },
            "3": { "name": "entity.name.tag.html.jsx" },
            "4": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [{ "include": "#jsx-attributes" }, { "include": "#jsx-children" }]
        }
      ]
    },
    "jsx-attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.jsx",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_:-]*\\b(?=\\s*=)"
        },
        {
          "name": "entity.other.attribute-name.jsx",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b(?=[\\s/>=])"
        },
        {
          "name": "keyword.operator.assignment.jsx",
          "match": "="
        },
        {
          "name": "punctuation.definition.tag.end.jsx",
          "match": ">"
        },
        {
          "name": "string.quoted.double.jsx",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.jsx", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.jsx",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.jsx", "match": "\\\\." }
          ]
        },
        {
          "name": "meta.embedded.expression.jsx",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.jsx" } },
          "endCaptures": { "0": { "name": "punctuation.section.embedded.end.jsx" } },
          "patterns": [{ "include": "$self" }]
        }
      ]
    },
    "jsx-children": {
      "patterns": [
        { "name": "meta.jsx.text.jsx", "match": "[^<>{}&]+" },
        { "include": "#jsx-embedded-expression" },
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-1" }
      ]
    },
    "jsx-embedded-expression": {
      "name": "meta.embedded.expression.jsx",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.jsx" } },
      "endCaptures": { "0": { "name": "punctuation.section.embedded.end.jsx" } },
      "patterns": [{ "include": "$self" }]
    },
    "jsx-children-level-1": {
      "patterns": [
        { "name": "meta.jsx.text.jsx", "match": "[^<>{}&]+" },
        { "include": "#jsx-embedded-expression" },
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-2" }
      ]
    },
    "jsx-children-level-2": {
      "patterns": [
        { "name": "meta.jsx.text.jsx", "match": "[^<>{}&]+" },
        { "include": "#jsx-embedded-expression" },
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-3" }
      ]
    },
    "jsx-children-level-3": {
      "patterns": [
        { "name": "meta.jsx.text.jsx", "match": "[^<>{}&]+" },
        { "include": "#jsx-embedded-expression" },
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-4" }
      ]
    },
    "jsx-children-level-4": {
      "patterns": [
        { "name": "meta.jsx.text.jsx", "match": "[^<>{}&]+" },
        { "include": "#jsx-embedded-expression" },
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-5" }
      ]
    },
    "jsx-children-level-5": {
      "patterns": [
        { "name": "meta.jsx.text.jsx", "match": "[^<>{}&]+" },
        { "include": "#jsx-embedded-expression" },
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-6" }
      ]
    },
    "jsx-children-level-6": {
      "patterns": [
        { "name": "meta.jsx.text.jsx", "match": "[^<>{}&]+" },
        { "include": "#jsx-embedded-expression" },
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-7" }
      ]
    },
    "jsx-children-level-7": {
      "patterns": [
        { "name": "meta.jsx.text.jsx", "match": "[^<>{}&]+" },
        { "include": "#jsx-embedded-expression" },
        { "include": "#jsx-fragment" },
        { "include": "#jsx-level-8" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.psr",
          "match": "\\b(if|else|switch|case|default|for|while|do|break|continue|return|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.other.psr",
          "match": "\\b(const|let|var|function|async|await|import|export|from|as|default|class|interface|type|enum|namespace)\\b"
        },
        {
          "name": "storage.modifier.psr",
          "match": "\\b(public|private|protected|readonly|static)\\b"
        },
        {
          "name": "constant.language.psr",
          "match": "\\b(true|false|null|undefined|NaN|Infinity)\\b"
        },
        {
          "name": "variable.language.psr",
          "match": "\\b(this|super)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.psr",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.psr",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.psr",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.psr",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.psr",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.template.expression.psr",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.psr",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.psr",
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.psr" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.psr",
          "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.psr",
          "match": "(\\+\\+|\\-\\-|\\+|\\-|\\*|\\/|%|===|!==|==|!=|<=|>=|<|>|&&|\\|\\||!|\\?|:|=|\\+=|\\-=|\\*=|\\/=|%=|=>)"
        }
      ]
    }
  }
}
